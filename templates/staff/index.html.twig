{% extends 'base.html.twig' %}

{% block title %}Staff{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>Staff</h1>
    <a href="{{ path('app_staff_new') }}" class="btn btn-primary">New Staff</a>
</div>
<table class="table table-striped">
    <thead><tr><th>Username</th><th>Name</th><th>Email</th><th>Producer</th><th></th></tr></thead>
    <tbody>
    {% for member in staff %}
        <tr>
            <td>{{ member.username }}</td>
            <td>{{ member.fullName }}</td>
            <td>{{ member.email }}</td>
            <td>{{ member.producer }}</td>
            <td><a href="{{ path('app_staff_edit', {username: member.username}) }}">Edit</a></td>
        </tr>
    {% else %}
        <tr><td colspan="5">No staff found.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
