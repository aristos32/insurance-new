{% extends 'base.html.twig' %}

{% block title %}Contracts{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>Contracts</h1>
    <a href="{{ path('app_sale_new') }}" class="btn btn-primary">New Contract</a>
</div>

<form class="row g-2 mb-3">
    <div class="col-md-9"><input class="form-control" name="q" value="{{ query }}" placeholder="Search contract or client..."></div>
    <div class="col-md-3"><button class="btn btn-secondary w-100">Search</button></div>
</form>

<table class="table table-hover">
    <thead><tr><th>Contract</th><th>Client</th><th>Type</th><th>Status</th><th>End</th><th>Balance</th></tr></thead>
    <tbody>
    {% for sale in sales %}
        <tr>
            <td><a href="{{ path('app_sale_show', {saleId: sale.saleId}) }}">{{ sale.saleId }}</a></td>
            <td>{{ sale.customer ? sale.customer.fullName : '-' }}</td>
            <td>{{ sale.insuranceType ? sale.insuranceType.value : '-' }}</td>
            <td>{{ sale.status ? sale.status.value : '-' }}</td>
            <td>{{ sale.endDate ? sale.endDate|date('Y-m-d') : '-' }}</td>
            <td>{{ sale.currentBalance|number_format(2) }} €</td>
        </tr>
    {% else %}
        <tr><td colspan="6">No contracts found.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
