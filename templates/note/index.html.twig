{% extends 'base.html.twig' %}

{% block title %}Notes{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>Notes</h1>
    <a href="{{ path('app_note_new') }}" class="btn btn-primary">New Note</a>
</div>
<table class="table table-striped">
    <thead><tr><th>Date</th><th>Type</th><th>Reference</th><th>Description</th></tr></thead>
    <tbody>
    {% for note in notes %}
        <tr>
            <td>{{ note.entryDate ? note.entryDate|date('Y-m-d H:i') : '-' }}</td>
            <td>{{ note.type ? note.type.value : '-' }}</td>
            <td>{{ note.parameterName }}={{ note.parameterValue }}</td>
            <td>{{ note.description }}</td>
        </tr>
    {% else %}
        <tr><td colspan="4">No notes.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
