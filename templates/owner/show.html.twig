{% extends 'base.html.twig' %}

{% block title %}Client {{ owner.stateId }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>{{ owner.fullName }} <small class="text-muted">({{ owner.stateId }})</small></h1>
    <div>
        <a href="{{ path('app_owner_edit', {stateId: owner.stateId}) }}" class="btn btn-outline-primary">Edit</a>
        <a href="{{ path('app_claim_new', {stateId: owner.stateId}) }}" class="btn btn-outline-secondary">Add Claim</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">Type</dt><dd class="col-sm-10">{{ owner.type ? owner.type.value : '-' }}</dd>
    <dt class="col-sm-2">Email</dt><dd class="col-sm-10">{{ owner.email }}</dd>
    <dt class="col-sm-2">Phone</dt><dd class="col-sm-10">{{ owner.telephone }}</dd>
    <dt class="col-sm-2">Company</dt><dd class="col-sm-10">{{ owner.company }}</dd>
</dl>

<h2 class="h4 mt-4">Contracts</h2>
<table class="table table-sm">
    <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>End</th><th>Balance</th></tr></thead>
    <tbody>
    {% for sale in owner.sales %}
        <tr>
            <td><a href="{{ path('app_sale_show', {saleId: sale.saleId}) }}">{{ sale.saleId }}</a></td>
            <td>{{ sale.insuranceType ? sale.insuranceType.value : '-' }}</td>
            <td>{{ sale.status ? sale.status.value : '-' }}</td>
            <td>{{ sale.endDate ? sale.endDate|date('Y-m-d') : '-' }}</td>
            <td>{{ sale.currentBalance|number_format(2) }} €</td>
        </tr>
    {% else %}
        <tr><td colspan="5">No contracts.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
