{% extends 'base.html.twig' %}

{% block title %}Expiring Contracts{% endblock %}

{% block body %}
<h1 class="mb-3">Contracts expiring in {{ days }} days</h1>
<table class="table table-striped">
    <thead><tr><th>Contract</th><th>Client</th><th>End Date</th><th>Status</th></tr></thead>
    <tbody>
    {% for sale in sales %}
        <tr>
            <td><a href="{{ path('app_sale_show', {saleId: sale.saleId}) }}">{{ sale.saleId }}</a></td>
            <td>{{ sale.customer.fullName }}</td>
            <td>{{ sale.endDate ? sale.endDate|date('Y-m-d') : '-' }}</td>
            <td>{{ sale.status ? sale.status.value : '-' }}</td>
        </tr>
    {% else %}
        <tr><td colspan="4">No contracts in this period.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
