{% extends 'base.html.twig' %}

{% block title %}Customers{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Customers & Leads</h1>
    <a href="{{ path('app_customer_new') }}" class="btn btn-primary">New Customer</a>
</div>

<form class="row g-2 mb-3">
    <div class="col-md-6"><input class="form-control" name="q" value="{{ query }}" placeholder="Search by name, ID, email..."></div>
    <div class="col-md-3">
        <select class="form-select" name="type">
            <option value="">All types</option>
            <option value="customer" {% if type and type.value == 'customer' %}selected{% endif %}>Customers</option>
            <option value="lead" {% if type and type.value == 'lead' %}selected{% endif %}>Leads</option>
        </select>
    </div>
    <div class="col-md-3"><button class="btn btn-secondary w-100">Search</button></div>
</form>

<table class="table table-hover">
    <thead><tr><th>State ID</th><th>Name</th><th>Type</th><th>Email</th><th>Phone</th><th></th></tr></thead>
    <tbody>
    {% for customer in customers %}
        <tr>
            <td>{{ customer.stateId }}</td>
            <td>{{ customer.fullName }}</td>
            <td>{{ customer.type ? customer.type.value : '-' }}</td>
            <td>{{ customer.email }}</td>
            <td>{{ customer.telephone }}</td>
            <td><a href="{{ path('app_customer_show', {stateId: customer.stateId}) }}">View</a></td>
        </tr>
    {% else %}
        <tr><td colspan="6">No customers found.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
