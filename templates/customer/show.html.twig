{% extends 'base.html.twig' %}

{% block title %}Customer {{ customer.stateId }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>{{ customer.fullName }} <small class="text-muted">({{ customer.stateId }})</small></h1>
    <div>
        {% if readOnly is not defined or not readOnly %}
        <a href="{{ path('app_customer_edit', {stateId: customer.stateId}) }}" class="btn btn-outline-primary">Edit</a>
        <a href="{{ path('app_claim_new', {stateId: customer.stateId}) }}" class="btn btn-outline-secondary">Add Claim</a>
        {% endif %}
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">Type</dt><dd class="col-sm-10">{{ customer.type ? customer.type.value : '-' }}</dd>
    <dt class="col-sm-2">Email</dt><dd class="col-sm-10">{{ customer.email }}</dd>
    <dt class="col-sm-2">Phone</dt><dd class="col-sm-10">{{ customer.telephone }}</dd>
    <dt class="col-sm-2">Company</dt><dd class="col-sm-10">{{ customer.company }}</dd>
</dl>

<h2 class="h4 mt-4">Contracts</h2>
<table class="table table-sm">
    <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>End</th><th>Balance</th></tr></thead>
    <tbody>
    {% for sale in customer.sales %}
        <tr>
            <td><a href="{{ path('app_sale_show', {saleId: sale.saleId}) }}">{{ sale.saleId }}</a></td>
            <td>{{ sale.insuranceType ? sale.insuranceType.value : '-' }}</td>
            <td>{{ sale.status ? sale.status.value : '-' }}</td>
            <td>{{ sale.endDate ? sale.endDate|date('Y-m-d') : '-' }}</td>
            <td>{{ sale.currentBalance|number_format(2) }} €</td>
        </tr>
    {% else %}
        <tr><td colspan="5">No contracts.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
