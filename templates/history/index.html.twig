{% extends 'base.html.twig' %}

{% block title %}History{% endblock %}

{% block body %}
<h1 class="mb-3">Audit History</h1>
<form class="row g-2 mb-3">
    <div class="col-md-9"><input class="form-control" name="q" value="{{ query }}" placeholder="Search by reference value..."></div>
    <div class="col-md-3"><button class="btn btn-secondary w-100">Search</button></div>
</form>
<table class="table table-sm">
    <thead><tr><th>Date</th><th>User</th><th>Type</th><th>Reference</th><th>Note</th></tr></thead>
    <tbody>
    {% for entry in entries %}
        <tr>
            <td>{{ entry.transDate ? entry.transDate|date('Y-m-d H:i') : '-' }}</td>
            <td>{{ entry.username }}</td>
            <td>{{ entry.type ? entry.type.value : '-' }}</td>
            <td>{{ entry.parameterName }}={{ entry.parameterValue }}</td>
            <td>{{ entry.note }}</td>
        </tr>
    {% else %}
        <tr><td colspan="5">No history entries.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
