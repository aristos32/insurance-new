{% extends 'base.html.twig' %}

{% block title %}Claims{% endblock %}

{% block body %}
<h1 class="mb-3">Claims</h1>
<table class="table table-striped">
    <thead><tr><th>Date</th><th>Client</th><th>Amount</th><th>Description</th></tr></thead>
    <tbody>
    {% for claim in claims %}
        <tr>
            <td>{{ claim.claimDate ? claim.claimDate|date('Y-m-d') : '-' }}</td>
            <td>{{ claim.owner ? claim.owner.fullName : '-' }}</td>
            <td>{{ claim.amount }}</td>
            <td>{{ claim.description }}</td>
        </tr>
    {% else %}
        <tr><td colspan="4">No claims.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
