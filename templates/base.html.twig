<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Insurance CRM{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_dashboard') }}">Insurance CRM</a>
        {% if app.user %}
        <div class="navbar-nav me-auto">
            <a class="nav-link" href="{{ path('app_owner_index') }}">Clients</a>
            <a class="nav-link" href="{{ path('app_sale_index') }}">Contracts</a>
            <a class="nav-link" href="{{ path('app_claim_index') }}">Claims</a>
            <a class="nav-link" href="{{ path('app_note_index') }}">Notes</a>
            <a class="nav-link" href="{{ path('app_history_index') }}">History</a>
            <a class="nav-link" href="{{ path('app_staff_index') }}">Staff</a>
            <a class="nav-link" href="{{ path('app_report_index') }}">Reports</a>
        </div>
        <span class="navbar-text text-white me-3">{{ app.user.userIdentifier }}</span>
        <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Logout</a>
        {% endif %}
    </div>
</nav>
<main class="container pb-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
