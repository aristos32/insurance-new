{% extends 'base.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1>Users</h1>
    <a href="{{ path('app_user_new') }}" class="btn btn-primary">New User</a>
</div>
<table class="table table-striped">
    <thead><tr><th>Username</th><th>Name</th><th>Email</th><th>Producer</th><th></th></tr></thead>
    <tbody>
    {% for user in users %}
        <tr>
            <td>{{ user.username }}</td>
            <td>{{ user.fullName }}</td>
            <td>{{ user.email }}</td>
            <td>{{ user.producer }}</td>
            <td><a href="{{ path('app_user_edit', {username: user.username}) }}">Edit</a></td>
        </tr>
    {% else %}
        <tr><td colspan="5">No users found.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
